<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MobileDev.Splash" parent="Theme.SplashScreen.IconBackground">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">@drawable/splash_window_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/splash_screen_round</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/white</item>
        <item name="windowSplashScreenBackground">@android:color/white</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.MobileDev</item>
    </style>
</resources>

