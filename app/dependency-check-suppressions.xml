        <notes>Netty 4.1.93 and 4.1.110 HTTP/2 and protocol handling vulnerabilities. Planned fix: Upgrade to 4.1.112+ in next sprint. See DEPENDENCY_UPDATES.md#DEPS-001</notes>
        <gav regex="true">^io\.netty:netty-.*:4\.1\.(93|110)\..*$</gav>
        <cve>CVE-2025-55163</cve>
        <cve>CVE-2025-24970</cve>
        <cve>CVE-2025-58057</cve>
        <cve>CVE-2025-58056</cve>
        <cve>CVE-2023-44487</cve>
        <cve>CVE-2023-34462</cve>
        <cve>CVE-2024-47535</cve>
        <cve>CVE-2024-29025</cve>
        <cve>CVE-2025-67735</cve>
        <cve>CVE-2025-25193</cve>
    </suppress>

    <!-- gRPC 1.57.2: HTTP/2 vulnerability -->
    <suppress>
        <notes>gRPC 1.57.2 CVE-2023-44487 (HTTP/2 stream multiplexing DoS). Planned fix: Upgrade to 1.68.0+ in next sprint. See DEPENDENCY_UPDATES.md#DEPS-002</notes>
        <gav regex="true">^io\.grpc:grpc-.*:1\.57\.2$</gav>
        <cve>CVE-2023-44487</cve>
    </suppress>

    <!-- Protobuf: 3.22.3, 3.24.4 JSON parsing vulnerability -->
    <suppress>
        <notes>Protobuf 3.22.3 and 3.24.4 CVE-2024-7254 (JSON deserialization). Planned fix: Upgrade to 3.25.0+ in next sprint. See DEPENDENCY_UPDATES.md#DEPS-003</notes>
        <gav regex="true">^com\.google\.protobuf:protobuf-.*:(3\.22\.3|3\.24\.4)$</gav>
        <cve>CVE-2024-7254</cve>
    </suppress>

    <!-- Kotlin: 1.6.10, 1.8.x, 1.9.0 reflection vulnerability -->
    <suppress>
        <notes>Kotlin CVE-2020-29582 (reflection utility). Low impact in Android client. Planned fix: Upgrade to 2.0.21 in next sprint. See DEPENDENCY_UPDATES.md#DEPS-004</notes>
        <gav regex="true">^org\.jetbrains\.kotlin:kotlin-.*:(1\.6\.10|1\.8\.|1\.9\.0).*$</gav>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <!-- Commons Lang 3.16.0 -->
    <suppress>
        <notes>Commons Lang 3.16.0 CVE-2025-48924. Low impact, update to 3.17.0 when handling other dependency updates. See DEPENDENCY_UPDATES.md#DEPS-005</notes>
        <gav regex="true">^org\.apache\.commons:commons-lang3:3\.16\.0$</gav>
        <cve>CVE-2025-48924</cve>
    </suppress>

    <!-- Apache HttpClient 4.5.6 -->
    <suppress>
        <notes>Apache HttpClient 4.5.6 CVE-2020-13956. Low impact due to HTTPS/TLS usage and Android context. Future fix: Replace with OkHttp3. See DEPENDENCY_UPDATES.md#DEPS-006</notes>
        <gav regex="true">^org\.apache\.httpcomponents:httpclient:4\.5\.6$</gav>
        <cve>CVE-2020-13956</cve>
    </suppress>

